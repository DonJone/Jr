#!/bin/bash

# ==========================================
# Journal CLI (jr) 
# ==========================================

# 颜色控制
BLUE='\033[0;34m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

# 1. 路径定义
JRNL_SYNC="$HOME/Documents/Journal"
JRNL_LOCAL="$HOME/Documents/Journal_local"

# 2. 并发锁：防止多个实例同时操作引发 Git 冲突
LOCKFILE="/tmp/jr_sync.lock"
exec 200>$LOCKFILE
flock -n 200 || { echo -e "${RED}Error: Another instance of jr is running.${NC}"; exit 1; }

# 3. 语言识别 (Language Detection)
[[ "$LANG" =~ ^en ]] && LANG_EN=true || LANG_EN=false

# 4. 国际化字符串定义 (i18n)
if [ "$LANG_EN" = true ]; then
    STR_USAGE="Usage:"
    STR_MODE_A="[Sync Mode] Record note and push to GitHub"
    STR_MODE_A_OPT="[Sync Mode] Open today's log in sync directory"
    STR_MODE_B="[Local Mode] Record to local directory (No Sync)"
    STR_MODE_B_OPT="[Local Mode] Open local log in local directory"
    STR_OPT_TITLE="Options (Mutually Exclusive):"
    STR_NOTE_HDR="Notes:"
    STR_NOTE_MAIN="Main Dir:  ~/Documents/Journal (Sync to GitHub)"
    STR_NOTE_LOCAL="Local Dir: ~/Documents/Journal_local (No Sync)"
    STR_ERR_LOCK="Error: Only one editor can be selected."
    STR_ERR_ARG="Error: Invalid argument"
    STR_SUCCESS="Success: Saved to"
    STR_ZONE_SYNC="Main Directory"
    STR_ZONE_LOCAL="Local Directory"
    STR_HEALING="Sync directory anomaly detected, self-healing..."
    STR_INIT="Initialized"
    STR_LOCAL_TAG="(Local Only)"
else
    STR_USAGE="用法 (Usage):"
    STR_MODE_A="记录笔记至本地并自动推送到 GitHub"
    STR_MODE_A_OPT="使用指定编辑器打开今日日志"
    STR_MODE_B="记录到备份目录，不上传云端"
    STR_MODE_B_OPT="使用指定编辑器打开本地日志并保存至备份"
    STR_OPT_TITLE="选项 (Options - 互斥使用):"
    STR_NOTE_HDR="说明 (Notes):"
    STR_NOTE_MAIN="主目录： ~/Documents/Journal (同步至GitHub)"
    STR_NOTE_LOCAL="本地目录：~/Documents/Journal_local（不同步）"
    STR_ERR_LOCK="错误: 只能选择一个编辑器选项。"
    STR_ERR_ARG="错误: 无效参数"
    STR_SUCCESS="成功: 内容已保存至"
    STR_ZONE_SYNC="主目录 (同步区)"
    STR_ZONE_LOCAL="本地目录 (隔离区)"
    STR_HEALING="检测到同步目录异常，正在自愈..."
    STR_INIT="已初始化"
    STR_LOCAL_TAG="(仅本地保存)"
fi

# 5. 帮助文档
show_help() {
    cat << EOF
$STR_USAGE
  jr "内容"                $STR_MODE_A
  jr [选项]                $STR_MODE_A_OPT

  jr -l "内容"             $STR_MODE_B
  jr -l [选项]             $STR_MODE_B_OPT

$STR_OPT_TITLE
  -c, --code              使用 Code OSS 打开
  -g, --gnome             使用 GNOME Text Editor / gedit 打开
  -k, --kde               使用 Kate 打开
  -m, --macos             使用 macOS TextEdit 打开
  -h, --help              显示此帮助信息

$STR_NOTE_HDR
  $STR_NOTE_MAIN
  $STR_NOTE_LOCAL
EOF
}

# 6. 参数解析与安全拦截
IS_LOCAL="false"
ACTION_COUNT=0
SELECTED_ACTION=""

for arg in "$@"; do
    [[ "$arg" == "-l" || "$arg" == "--local" ]] && IS_LOCAL="true"
    if [[ "$arg" =~ ^-{2,} && "$arg" != "--local" && "$arg" != "--help" && "$arg" != "--code" && "$arg" != "--gnome" && "$arg" != "--kde" && "$arg" != "--macos" ]]; then
        echo -e "${RED}$STR_ERR_ARG '$arg'.${NC}" >&2; exit 1
    fi
done

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help) show_help; exit 0 ;;
        -l|--local) shift ;; 
        -c|--code|-g|--gnome|-k|--kde|-m|--macos)
            ((ACTION_COUNT++)); SELECTED_ACTION="$1"; shift ;;
        -*) echo -e "${RED}$STR_ERR_ARG '$1'.${NC}" >&2; exit 1 ;;
        *) TEXT_CONTENT="$*"; break ;;
    esac
done

[[ "$ACTION_COUNT" -gt 1 ]] && { echo -e "${RED}$STR_ERR_LOCK${NC}" >&2; exit 1; }

# 7. 路径、鉴权与自愈环境
TARGET_BASE="$JRNL_SYNC"
[[ "$IS_LOCAL" == "true" ]] && TARGET_BASE="$JRNL_LOCAL"

if [[ "$IS_LOCAL" == "false" ]]; then
    if ! gh auth status >/dev/null 2>&1; then
        echo -e "${YELLOW}提示: 检测到未登录 GitHub，云端同步需要授权。${NC}"
        read -p "是否立即配置 GitHub 登录？(y/n): " LOGIN_CHOICE
        if [[ "$LOGIN_CHOICE" =~ ^[Yy]$ ]]; then
            gh auth login
            if ! gh auth status >/dev/null 2>&1; then
                echo -e "${RED}授权未成功，为防止数据丢失，本次操作将降级为仅本地保存。${NC}"
                IS_LOCAL="true"
                TARGET_BASE="$JRNL_LOCAL"
            fi
        else
            echo -e "${YELLOW}已跳过授权，本次操作将降级为仅本地保存 (-l)。${NC}"
            IS_LOCAL="true"
            TARGET_BASE="$JRNL_LOCAL"
        fi
    fi
fi

if [[ "$IS_LOCAL" == "false" ]]; then
    if [ -d "$JRNL_SYNC" ] && [ ! -d "$JRNL_SYNC/.git" ]; then
        echo -e "${YELLOW}$STR_HEALING${NC}"
        TMP_RECOVERY_DIR="${JRNL_SYNC}_recovery_$(date +%s)"
        mv "$JRNL_SYNC" "$TMP_RECOVERY_DIR"
        
        if gh repo clone Journal "$JRNL_SYNC" >/dev/null 2>&1; then
            find "$TMP_RECOVERY_DIR" -name "*.md" -type f | while read -r backup_file; do
                relative_path="${backup_file#$TMP_RECOVERY_DIR/}"
                target_file="$JRNL_SYNC/$relative_path"
                mkdir -p "$(dirname "$target_file")"
                if [ -f "$target_file" ]; then
                    echo -e "\n--- [Recovered Content $(date +'%Y-%m-%d %H:%M:%S')] ---\n" >> "$target_file"
                    cat "$backup_file" >> "$target_file"
                else
                    cp "$backup_file" "$target_file"
                fi
            done
            rm -rf "$TMP_RECOVERY_DIR"
            echo -e "${GREEN}自愈成功：本地数据已合并至新仓库。${NC}"
        else
            mv "$TMP_RECOVERY_DIR" "$JRNL_SYNC"
            echo -e "${RED}自愈失败：无法连接到 GitHub。已保留原始本地文件。${NC}"
            exit 1
        fi
    elif [ ! -d "$JRNL_SYNC" ]; then
        echo -e "${BLUE}>>> 正在同步云端环境...${NC}"
        if gh repo view Journal >/dev/null 2>&1; then
            gh repo clone Journal "$JRNL_SYNC" >/dev/null 2>&1
        else
            echo -e "${YELLOW}未检测到远端仓库，正在自动创建并初始化私有仓库...${NC}"
            mkdir -p "$JRNL_SYNC"
            (
                cd "$JRNL_SYNC" || exit 1
                git init -b main
                git commit --allow-empty -m "Initial commit"
                gh repo create Journal --private --source=. --remote=origin --push
            ) >/dev/null 2>&1
        fi
    fi
fi

if [[ "$IS_LOCAL" == "true" ]]; then
    mkdir -p "$JRNL_LOCAL"
fi

# 8. 时间与文件解析
YEAR=$(date +'%Y')
MONTH=$(date +'%m')
CURRENT_DATE=$(date +'%Y-%m-%d'); CURRENT_TIME=$(date +'%H:%M:%S')
TARGET_DIR="${TARGET_BASE}/${YEAR}/${MONTH}"

FILE_SUFFIX=""
[[ "$IS_LOCAL" == "true" ]] && FILE_SUFFIX="_local"
FILE_NAME="${TARGET_DIR}/${CURRENT_DATE}${FILE_SUFFIX}.md"

mkdir -p "$TARGET_DIR"
if [ ! -f "$FILE_NAME" ]; then
    HEADER="# $CURRENT_DATE 日志"
    [[ "$IS_LOCAL" == "true" ]] && HEADER="$HEADER $STR_LOCAL_TAG"
    echo -e "$HEADER\n" > "$FILE_NAME"
    echo "$STR_INIT: $FILE_NAME"
fi

# 9. 执行动作
if [ -n "$SELECTED_ACTION" ]; then
    case "$SELECTED_ACTION" in
        -c|--code)  code --new-window --wait "$FILE_NAME" ;;
        -g|--gnome)
            G_CMD=$(command -v gnome-text-editor || command -v gedit)
            [ -n "$G_CMD" ] && "$G_CMD" --new-window --wait "$FILE_NAME" ;;
        -k|--kde)   kate --new --block "$FILE_NAME" ;;
        -m|--macos) open -W -n -t "$FILE_NAME" ;;
    esac
elif [ -n "$TEXT_CONTENT" ]; then
    echo -e "## $CURRENT_TIME\n$TEXT_CONTENT\n" >> "$FILE_NAME"
    echo -e "${GREEN}$STR_SUCCESS $([[ "$IS_LOCAL" == "true" ]] && echo "$STR_ZONE_LOCAL" || echo "$STR_ZONE_SYNC")。${NC}"
fi

# 10. Git 自动同步 (仅限主目录模式)
if [[ "$IS_LOCAL" == "false" ]]; then
    (
        cd "$JRNL_SYNC" || exit 1
        git add .
        if [[ -n $(git status --porcelain) ]]; then
            LOCAL_BRANCH=$(git branch --show-current)
            [[ -z "$LOCAL_BRANCH" ]] && LOCAL_BRANCH="main"
            
            git commit -m "update: $CURRENT_TIME" --quiet
            # 允许首次 pull 报错（远端尚无同名分支时），随后强推建立追踪
            git pull origin "$LOCAL_BRANCH" --rebase --quiet >/dev/null 2>&1 || true
            git push -u origin "$LOCAL_BRANCH" --quiet >/dev/null 2>&1
        fi
    ) >/dev/null 2>&1
fi